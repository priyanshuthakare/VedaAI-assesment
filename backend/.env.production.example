# ============================================================
# VedaAI Backend – Production Environment Variables (Render)
# Copy these values into your Render service's Environment tab
# ============================================================

NODE_ENV=production
PORT=4000

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://vedaai-admin:<PASSWORD>@vedaai-cluster.xxxxx.mongodb.net/vedaai?retryWrites=true&w=majority

# ── Upstash Redis REST (general-purpose caching) ─────────────
# Used by: src/config/redis.ts in production
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# ── Upstash Redis TLS endpoint (for BullMQ workers) ──────────
# BullMQ requires ioredis protocol, NOT the REST API
REDIS_TLS_URL=rediss://default:xxxxx@xxx.upstash.io:6379

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Optional / Future ─────────────────────────────────────────
JWT_SECRET=your_random_secret_here
